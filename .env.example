# evoWeb Server Configuration
# The port the backend server will listen on
PORT=3330
NODE_ENV=development
DEBUG=true

# Provider Selection: 'honeywell', 'mqtt', or 'mock'
HEATING_PROVIDER=honeywell

# Honeywell TCC Credentials (Required for 'honeywell' mode)
HONEYWELL_USERNAME=your_email@example.com
HONEYWELL_PASSWORD=your_password

# MQTT Configuration (Required for 'mqtt' mode)
# Default broker URL (use 'bridgeserver' if using the standard evogateway setup)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT Topic templates (defaults match standard evogateway structure)
MQTT_COMMAND_TOPIC=evohome/evogateway/system/_command
MQTT_STATUS_TOPIC=evohome/evogateway/system/_command/_lastcommand
MQTT_ZONES_TOPIC=evohome/evogateway/zones
