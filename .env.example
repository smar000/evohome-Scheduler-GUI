# =============================================================================
# evoWeb Configuration
# Copy this file to .env and fill in the required values.
# Lines beginning with # are comments and are ignored at runtime.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# Port the HTTP server listens on.
PORT=3330

NODE_ENV=production

# Set to true to enable verbose debug logging.
DEBUG=false

# -----------------------------------------------------------------------------
# Provider Selection
# -----------------------------------------------------------------------------
# Controls which data source drives the Scheduler tab and the /rest/getcurrentstatus
# endpoints. Both cloud and local providers are initialised concurrently at startup
# (as long as their credentials are present below), so REST endpoints for each are
# always available regardless of this setting.
#
# Valid values: honeywell | mqtt | mock
HEATING_PROVIDER=honeywell

# -----------------------------------------------------------------------------
# Honeywell TCC — Cloud Provider
# -----------------------------------------------------------------------------
# Required if HEATING_PROVIDER=honeywell or if cloud REST endpoints are needed.
# Both USERNAME and PASSWORD must be set for the cloud provider to initialise.
HONEYWELL_USERNAME=your-email@example.com
HONEYWELL_PASSWORD=your-password

# -----------------------------------------------------------------------------
# MQTT — Local Provider (evogateway)
# -----------------------------------------------------------------------------
# Required if HEATING_PROVIDER=mqtt or if local REST endpoints are needed.
# Leave USERNAME and PASSWORD blank if the broker does not require authentication.
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT topic structure published by evogateway.
MQTT_BASE_TOPIC=evohome/evogateway
MQTT_ZONES_SUBTOPIC=zones
MQTT_DHW_SUBTOPIC=_dhw

# =============================================================================
# Advanced Configuration (uncomment to override defaults)
# =============================================================================

# -----------------------------------------------------------------------------
# Honeywell TCC — Advanced
# -----------------------------------------------------------------------------

# Short-term cache TTL (minutes).
# Responses from the Honeywell API are cached for this duration. Any status
# request within this window is served from cache without an API call.
# Default: 3
# HONEYWELL_CACHE_TTL=3

# Auto-refresh ceiling (minutes).
# If cached data is older than this threshold, any incoming status request —
# even one without ?refresh=1 — will trigger a fresh API call. This prevents
# stale data being served to external REST consumers after a quiet period.
# Default: 15
# HONEYWELL_AUTO_REFRESH=15

# Minimum gap between full password re-authentications (minutes).
# The app uses OAuth token refresh wherever possible. A full password login is
# only attempted if the refresh token has also expired. This guard prevents
# accidental rapid re-login loops that could trigger Honeywell rate limiting.
# Default: 15
# HONEYWELL_LOGIN_LIMIT=15

# Base URL for the Honeywell TCC API. Change only if Honeywell updates the domain.
# Default: https://mytotalconnectcomfort.com
# HONEYWELL_URL_DOMAIN=https://mytotalconnectcomfort.com

# HTTP request timeout for Honeywell API calls (milliseconds).
# Default: 10000
# HONEYWELL_API_TIMEOUT=10000

# -----------------------------------------------------------------------------
# MQTT — Advanced
# -----------------------------------------------------------------------------

# Time between MQTT reconnection attempts (milliseconds). Default: 5000
# MQTT_RECONNECT_PERIOD=5000

# Maximum time to wait for the initial MQTT connection (milliseconds). Default: 10000
# MQTT_CONNECT_TIMEOUT=10000

# Window (milliseconds) within which retained MQTT messages are accepted on
# startup before being treated as stale. Default: 1000
# MQTT_RETAINED_WINDOW=1000

# Timeout waiting for a schedule response over MQTT (milliseconds). Default: 10000
# MQTT_SCHEDULE_TIMEOUT=10000

# Days after which a cached MQTT zone schedule is considered stale and auto-refreshed on zone selection (default: 7)
MQTT_SCHEDULE_STALE_DAYS=7

# -----------------------------------------------------------------------------
# Scheduler & UI
# -----------------------------------------------------------------------------

# Minimum time-slot granularity in the schedule grid (minutes). Default: 10
# SCHEDULER_TIME_RESOLUTION=10

# Default target temperature for newly created schedule slots (°C). Default: 20
# SCHEDULER_DEFAULT_TEMP=20

# Duration of a long-press gesture to trigger slot split/delete (milliseconds). Default: 600
# SCHEDULER_LONG_PRESS_MS=600

# Timeout for frontend API calls (milliseconds). Default: 15000
# FRONTEND_API_TIMEOUT=15000

# -----------------------------------------------------------------------------
# Hot water (DHW) slot colours
# -----------------------------------------------------------------------------
# Hex colours for DHW schedule slots. ON = water heating active, OFF = inactive.
# DHW_COLORS='{"on":"#6366f1","off":"#e2e8f0"}'

# Temperature colour thresholds
# -----------------------------------------------------------------------------
# JSON array mapping temperature thresholds to hex colours in the schedule grid.
# Entries must be in ascending maxTemp order. The final entry (no maxTemp field)
# is used for any temperature above all listed thresholds.
# TEMP_COLORS='[{"maxTemp":5,"color":"#94a3b8"},{"maxTemp":14,"color":"#2563eb"},{"maxTemp":16,"color":"#0891b2"},{"maxTemp":18,"color":"#0d9488"},{"maxTemp":20,"color":"#059669"},{"maxTemp":22,"color":"#d97706"},{"maxTemp":23,"color":"#ea580c"},{"maxTemp":25,"color":"#dc2626"},{"color":"#9f1239"}]'
