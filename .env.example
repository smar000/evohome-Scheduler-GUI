# Server Configuration
PORT=3330
NODE_ENV=development
DEBUG=true

# Provider Selection: 'honeywell', 'mqtt', or 'mock'
HEATING_PROVIDER=mock

# Honeywell TCC Credentials
HONEYWELL_USERNAME=your_username
HONEYWELL_PASSWORD=your_password

# MQTT Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_PREFIX=evohome
