# General
PORT=3330
NODE_ENV=production
DEBUG=false

# Provider Selection: 'honeywell' (Cloud) or 'mqtt' (Local)
HEATING_PROVIDER=honeywell

# Honeywell TCC (Cloud) Credentials
HONEYWELL_USERNAME=your-email@example.com
HONEYWELL_PASSWORD=your-password

# MQTT (Local) Configuration
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# MQTT Topic Configuration (Rationalized)
# Base topic for the evogateway
MQTT_BASE_TOPIC=evohome/evogateway
# Subtopic for zones (default 'zones')
MQTT_ZONES_SUBTOPIC=zones
# Subtopic for hot water (default '_dhw')
MQTT_DHW_SUBTOPIC=_dhw

# --- Advanced Configuration ---

# Honeywell TCC Settings
# HONEYWELL_CACHE_TTL=3
# HONEYWELL_URL_DOMAIN=https://mytotalconnectcomfort.com
# HONEYWELL_API_TIMEOUT=10000
# HONEYWELL_LOGIN_LIMIT=15

# MQTT Settings
# MQTT_RECONNECT_PERIOD=5000
# MQTT_CONNECT_TIMEOUT=10000
# MQTT_RETAINED_WINDOW=1000
# MQTT_SCHEDULE_TIMEOUT=10000

# Scheduler & UI Settings
# SCHEDULER_TIME_RESOLUTION=10
# SCHEDULER_DEFAULT_TEMP=20
# SCHEDULER_LONG_PRESS_MS=600
# FRONTEND_API_TIMEOUT=15000
